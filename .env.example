# Variables consumed by docker-compose.yml (frontend build args + CORS).
# Copy to ".env" and fill in. Backend runtime secrets live in backend/.env instead.

# Public URL the browser uses to reach the backend API.
VITE_API_URL=http://localhost:8080

# Origin the frontend is served from (used to lock down backend CORS).
FRONTEND_ORIGIN=http://localhost:3000

# Supabase project URL and anon key (frontend, build-time).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
